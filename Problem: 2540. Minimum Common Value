// Optimal Solutions: 
class Solution {
    public int getCommon(int[] nums1, int[] nums2) {
        int i = 0, j = 0;
        while(i < nums1.length && j < nums2.length){
            if(nums1[i] == nums2[j]){
                return nums1[i];
            }
            else if(nums1[i] < nums2[j]){
                i++;
            }
            else{
                j++;
            }
        }
        return -1;
        

        
    }
}
// Time Complexity : O( m + n)  m = nums1 length and n = nums2 length
// Space Complexity : O(1)



