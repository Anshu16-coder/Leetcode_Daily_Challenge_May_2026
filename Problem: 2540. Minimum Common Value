// Problem Statements : Minimum Common Value

// My Approach 1st : HashSet

class Solution {
    public int getCommon(int[] nums1, int[] nums2) {

        HashSet<Integer> hs = new HashSet<>();
        for(int i = 0; i < nums1.length; i++){
            hs.add(nums1[i]);
        }
        for(int j = 0; j < nums2.length; j++){
            if(hs.contains(nums2[j])){
                return nums2[j];
              
            }
        }
        return -1;
        
    }
}

// Time Complexity : O(n)    length of nums1 + length of nums2 
// Space Complexity : O(n)   HashSet stores nums1 (length of nums1)   


